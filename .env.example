# =============================================================================
# CONVO — Environment Variables
# Copie este arquivo para .env e preencha os valores.
# Nunca comite o .env real. Este arquivo (.env.example) é versionado.
# =============================================================================

# =============================================================================
# APP
# =============================================================================
ENVIRONMENT=development
# debug habilita SQL echo e traceback detalhado
DEBUG=true
# Chave interna do FastAPI (sessões, CSRF) — gere com: openssl rand -hex 32
SECRET_KEY=change-me-in-production-generate-with-openssl-rand-hex-32
# Lista de origens permitidas no CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://convo.app

# =============================================================================
# DATABASE — PostgreSQL via Neon (prod) ou docker-compose (dev)
# =============================================================================
# Formato asyncpg para SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://convo:convo@localhost:5432/convo
# URL síncrona usada apenas pelo Alembic (migrações)
SYNC_DATABASE_URL=postgresql://convo:convo@localhost:5432/convo

# =============================================================================
# REDIS — Upstash (prod) ou docker-compose (dev)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CLERK AUTH
# Obtenha no dashboard: https://dashboard.clerk.com → API Keys
# =============================================================================
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# JWKS URL para verificar JWTs no backend
# Formato: https://<sua-instância>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Webhook secret (Clerk → Convo) — obtido em Clerk > Webhooks
CLERK_WEBHOOK_SECRET=whsec_...

# =============================================================================
# ENCRYPTION — Fernet key para criptografar chaves de API dos clientes
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================
ENCRYPTION_KEY=gere-com-o-comando-acima

# =============================================================================
# CELERY — defaults para REDIS_URL se não preenchidos
# =============================================================================
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# =============================================================================
# MIGRATIONS
# Em dev, seta RUN_MIGRATIONS=true para rodar alembic upgrade head no startup.
# Em prod, usar o script migrate.sh no pipeline de CI/CD.
# =============================================================================
RUN_MIGRATIONS=true

# =============================================================================
# OBSERVABILIDADE
# =============================================================================
# Sentry — obtenha em sentry.io
SENTRY_DSN=https://...@sentry.io/...
# Logfire — obtenha em logfire.dev
LOGFIRE_TOKEN=...

# =============================================================================
# LLMs DO CONVO (onboarder + supervisor — custo pago pelo Convo, não pelo cliente)
# Claude Haiku 4.5 para onboarder, Claude Sonnet para supervisor
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# Fallback / testes internos
OPENAI_API_KEY=sk-...

# =============================================================================
# ZAPI — credenciais POR TENANT ficam no banco (criptografadas).
# As variáveis abaixo são apenas para testes locais / smoke tests.
# =============================================================================
ZAPI_TEST_INSTANCE_ID=
ZAPI_TEST_INSTANCE_TOKEN=
ZAPI_TEST_CLIENT_TOKEN=
# Base URL da Z-API (não mude a menos que use instância on-premise)
ZAPI_BASE_URL=https://api.z-api.io

# =============================================================================
# STRIPE — Sprint 7 (billing)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_PRICE_ID_SCALE=price_...

# =============================================================================
# EMAIL — Resend (transacional, Sprint 7)
# =============================================================================
RESEND_API_KEY=re_...
FROM_EMAIL=no-reply@convo.app

# =============================================================================
# FRONTEND — Next.js (estas vão em frontend/.env.local)
# Variáveis com NEXT_PUBLIC_ são expostas ao browser
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Rotas do Clerk no Next.js
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
