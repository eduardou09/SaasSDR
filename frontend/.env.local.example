# Copie para .env.local e preencha
# Variáveis com NEXT_PUBLIC_ são expostas ao browser

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Recomendado em dev: usar proxy interno do Next para evitar CORS/localhost mismatch
NEXT_PUBLIC_API_URL=/api/backend
NEXT_PUBLIC_WS_URL=ws://localhost:8000
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Rotas do Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Server-side only (não exposta ao browser)
CLERK_SECRET_KEY=sk_test_...
